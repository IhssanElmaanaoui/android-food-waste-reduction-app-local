<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btnBackAuth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Retour Auth" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Admin"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAdminUserEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Email utilisateur"
            android:inputType="textEmailAddress" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAdminSetClient"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Role Client" />

            <Button
                android:id="@+id/btnAdminSetMerchant"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Role Merchant" />
        </LinearLayout>

        <EditText
            android:id="@+id/etAdminCommerceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Nom commerce a supprimer"
            android:inputType="text" />

        <Button
            android:id="@+id/btnAdminDeleteCommerce"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Supprimer commerce" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Utilisateurs"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdminUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#EEEEEE"
            android:minHeight="90dp"
            android:padding="10dp"
            android:text="Aucun utilisateur" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Commerces"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdminCommerces"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#EEEEEE"
            android:minHeight="90dp"
            android:padding="10dp"
            android:text="Aucun commerce" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Reservations (systeme)"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdminReservations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp"
            android:background="#EEEEEE"
            android:minHeight="90dp"
            android:padding="10dp"
            android:text="Aucune reservation" />
    </LinearLayout>
</ScrollView>
